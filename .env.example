# Application metadata
APP_NAME=LabKAG
APP_VERSION=0.1.0

# Local storage paths
DATA_DIR=data
UPLOAD_DIR=data/uploads
PARSED_DIR=data/parsed
EXTRACTION_DIR=data/extractions

# Primary graph backend settings used when ingest confirm=true.
GRAPH_BACKEND=neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# OpenAI-compatible Chat Completions settings for M3 literature extraction.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60

# OpenAI-compatible embeddings settings for M9 vector retrieval.
ENABLE_EMBEDDING=true
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_TIMEOUT_SECONDS=60
