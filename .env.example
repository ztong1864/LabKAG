# Application metadata
APP_NAME=LabKAG
APP_VERSION=0.1.0

# Local storage paths
DATA_DIR=data
UPLOAD_DIR=data/uploads
PARSED_DIR=data/parsed
EXTRACTION_DIR=data/extractions

# KAG/OpenSPG adapter mode
# true keeps KAG/OpenSPG calls in local mock mode for v0.1 development.
MOCK_KAG=true

# OpenSPG write settings used when MOCK_KAG=false and ingest confirm=true.
OPENSPG_BASE_URL=http://127.0.0.1:8887
# http uses OPENSPG_WRITE_PATH; neo4j writes to the graph store from the local
# OpenSPG compose deployment while the OpenSPG REST data write API is still
# being validated.
OPENSPG_WRITE_BACKEND=http
OPENSPG_WRITE_PATH=/api/graph/write
OPENSPG_API_KEY=
# Optional OpenSPG UI/API login credentials. Current OpenSPG images use cookie
# login for many /v1 endpoints; leave empty when using mock mode or API-key mode.
OPENSPG_ACCOUNT=
OPENSPG_PASSWORD=
OPENSPG_PROJECT_ID=
# Human-readable OpenSPG project lookup fields for real writes.
OPENSPG_PROJECT_NAME=LabKAG
OPENSPG_NAMESPACE=LabKAG
OPENSPG_TIMEOUT_SECONDS=30
# Neo4j graph-store settings used when OPENSPG_WRITE_BACKEND=neo4j.
OPENSPG_NEO4J_URI=neo4j://127.0.0.1:7687
OPENSPG_NEO4J_USER=neo4j
OPENSPG_NEO4J_PASSWORD=
OPENSPG_NEO4J_DATABASE=neo4j

# Extraction mode
# true allows development fallback to the mock extractor when LLM_API_KEY is empty,
# and allows requests with extract_level=mock.
# false makes extraction fail if the real LLM extractor is unavailable.
ALLOW_MOCK_EXTRACTOR=true

# OpenAI-compatible Chat Completions settings for M3 literature extraction.
# Leave LLM_API_KEY empty only when ALLOW_MOCK_EXTRACTOR=true.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
