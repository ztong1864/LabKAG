# OpenSPG backend stack for local LabKAG integration.
OPENSPG_CONTAINER_PREFIX=labkag
TZ=Asia/Shanghai

# Server
OPENSPG_SERVER_PORT=8887
OPENSPG_SERVER_XMS=2048m
OPENSPG_SERVER_XMX=8192m

# MySQL
OPENSPG_MYSQL_PORT=3306
OPENSPG_MYSQL_ROOT_PASSWORD=openspg
OPENSPG_MYSQL_DATABASE=openspg

# Neo4j
OPENSPG_NEO4J_HTTP_PORT=7474
OPENSPG_NEO4J_BOLT_PORT=7687
OPENSPG_NEO4J_USER=neo4j
OPENSPG_NEO4J_PASSWORD=openspgneo4j
OPENSPG_NEO4J_HEAP_INIT=1G
OPENSPG_NEO4J_HEAP_MAX=4G
OPENSPG_NEO4J_PAGECACHE=1G
